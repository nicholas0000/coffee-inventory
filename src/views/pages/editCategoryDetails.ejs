<header class="p-8">
  <h1 class="text-2xl">Edit category details</h1>
</header>
<section class="px-8 flex-1">
  <%- include("../components/errorsList") %>
  <%- include("../components/forms/categoryForm", { category, route: `/categories/${category.id}/edit-details/save` }) %>
</section>
<footer class="flex gap-2 p-6 border border-base-200">
  <input type="submit" form="category-form" value="Save" class="btn btn-primary" />
  <a role="button" class="btn bg-white text-gray-500 border-gray-400" href="/categories/<%= category.id %>">Cancel</a>
</footer>